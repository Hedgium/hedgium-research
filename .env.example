# Copy to .env and adjust values
SECRET_KEY=change-me-in-production
DJANGO_DEBUG=True
ENVIRONMENT=local
ALLOWED_HOSTS=localhost,127.0.0.1

# Postgres (recommended). Leave empty to use SQLite (research.sqlite3).
DATABASE_URL=postgresql://hedgium:hedgium@localhost:5433/hedgium_research

# Redis DB 1 — separate from hedgium_backend (typically DB 0)
REDIS_URL=redis://localhost:6380/1

CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Optional: link to trading backend for Kite credentials
HEDGIUM_BACKEND_API_URL=http://127.0.0.1:8000/api
HEDGIUM_BACKEND_API_KEY=
HEDGIUM_INTERNAL_SERVICE_TOKEN=

# Or set Kite credentials directly
KITE_API_KEY=
KITE_ACCESS_TOKEN=

# Required in non-local environments
RESEARCH_API_KEY=

# Agent provider config (Phase 4)
AGENT_ENABLE=True
AGENT_PROVIDER=openai
AGENT_TIMEOUT_SEC=30
AGENT_MAX_TOKENS=1200
AGENT_PRECOMPUTE_ENABLED=False

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# --- Railway (dev / prod) ---
# ENVIRONMENT=dev          # or prod
# DJANGO_DEBUG=False
# DATABASE_URL=            # from Railway Postgres plugin
# REDIS_URL=               # from Railway Redis plugin
# ALLOWED_HOSTS=           # optional; RAILWAY_PUBLIC_DOMAIN is appended automatically
# CSRF_TRUSTED_ORIGINS=https://your-service.up.railway.app
# CORS_ALLOWED_ORIGINS=https://app.hedgium.ai
